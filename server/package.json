    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@prisma/config": "^7.7.0",
    "axios": "^1.7.2",
    "bullmq": "^5.30.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "expo-server-sdk": "^6.1.0",
    "express": "^4.21.0",
    "form-data": "^4.0.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
