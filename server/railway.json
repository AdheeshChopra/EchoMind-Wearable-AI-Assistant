{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKER",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "node dist/index.js",
    "healthCheckPath": "/api/health",
    "healthCheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE"
  }
}
