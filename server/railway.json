{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": ["src/**", "prisma/**", "package.json", "nixpacks.toml"]
  },
  "deploy": {
    "startCommand": "npm start",
    "healthCheckPath": "/api/health",
    "healthCheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE"
  }
}
