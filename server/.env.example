# ─── EchoMind AI Server Environment Variables ─────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
# ────────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=8080

# Database (PostgreSQL with pgvector)
DATABASE_URL=postgresql://user:password@localhost:5432/echomind?schema=public

# Redis (BullMQ queues: embedding, notification, ai-processing)
# Install Redis: https://redis.io/download or use Docker: docker run -d -p 6379:6379 redis
REDIS_URL=redis://localhost:6379

# Google AI (Gemini + Embeddings)
GOOGLE_API_KEY=your-google-api-key-here

# Whisper STT (Phase 2 — streaming audio)
WHISPER_URL=http://localhost:8000

# Authentication (JWT)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-at-least-32-characters-long
JWT_REFRESH_SECRET=your-refresh-secret-at-least-32-characters-long
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=*

# Feature Flags
DEMO_MODE=false
