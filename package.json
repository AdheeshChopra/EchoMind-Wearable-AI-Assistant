{
  "name": "echomind-ai",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "server",
    "client",
    "mobile"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:server": "turbo run dev --filter=echomind-server",
    "dev:client": "turbo run dev --filter=client",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean",
    "db:migrate": "cd server && npx prisma migrate dev",
    "db:generate": "cd server && npx prisma generate",
    "db:studio": "cd server && npx prisma studio"
  },
  "devDependencies": {
    "react-native": "^0.74.5",
    "turbo": "^2.5.0"
  }
}
