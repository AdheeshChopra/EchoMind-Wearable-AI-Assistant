{
  "expo": {
    "name": "EchoMind AI",
    "slug": "echomind-ai",
    "version": "1.0.0",
    "scheme": "echomind",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "android": {
      "package": "com.aryanmanhas.echomind",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "EchoMind needs access to your microphone to transcribe your voice."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e183b778-c783-4445-8cd6-8ae59ed24e8c"
      }
    }
  }
}
